#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
DOTFILES_WORK_TREE="${DOTFILES_WORK_TREE:-$HOME}"
ZSHRC_PATH="${ZSHRC_PATH:-$HOME/.zshrc}"
BASHRC_PATH="${BASHRC_PATH:-$HOME/.bashrc}"
ZSHRC_MANAGED_PATH="${ZSHRC_MANAGED_PATH:-$HOME/.zshrc.kalle}"
BASHRC_MANAGED_PATH="${BASHRC_MANAGED_PATH:-$HOME/.bashrc.kalle}"

log() {
  printf '[migrate-shell-rc] %s\n' "$*"
}

fail() {
  printf '[migrate-shell-rc] ERROR: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

dotfiles_git() {
  /usr/bin/git -C "$DOTFILES_WORK_TREE" --git-dir="$DOTFILES_DIR" --work-tree="$DOTFILES_WORK_TREE" "$@"
}

remove_from_index() {
  local rel_path="$1"
  dotfiles_git update-index --force-remove -- "$rel_path"
}

path_relative_to_work_tree() {
  local path="$1"

  case "$path" in
    "$DOTFILES_WORK_TREE")
      printf '.\n'
      ;;
    "$DOTFILES_WORK_TREE"/*)
      printf '%s\n' "${path#"$DOTFILES_WORK_TREE"/}"
      ;;
    *)
      return 1
      ;;
  esac
}

is_tracked() {
  local rel_path="$1"
  /usr/bin/git --git-dir="$DOTFILES_DIR" ls-files --stage -- "$rel_path" | grep -Fq "$rel_path"
}

validate_repo() {
  need_cmd git
  [[ -d "$DOTFILES_DIR" ]] || fail "$DOTFILES_DIR does not exist"
  [[ "$(/usr/bin/git --git-dir="$DOTFILES_DIR" rev-parse --is-bare-repository 2>/dev/null || true)" == "true" ]] || fail "$DOTFILES_DIR is not a bare git repository"
}

remove_stray_readme() {
  local readme_path="${DOTFILES_DIR}/README.md"
  local readme_rel

  readme_rel="$(path_relative_to_work_tree "$readme_path" || true)"

  if [[ -e "$readme_path" || -L "$readme_path" ]]; then
    rm -f "$readme_path"
    log "Removed stray bare-repo file $readme_path"
  fi

  if [[ -n "$readme_rel" ]] && is_tracked "$readme_rel"; then
    remove_from_index "$readme_rel"
    log "Removed tracked $readme_rel from the dotfiles index"
  fi
}

rename_shell_file() {
  local source_path="$1"
  local target_path="$2"
  local source_rel target_rel
  local source_tracked=0

  source_rel="$(path_relative_to_work_tree "$source_path")" || fail "Path is outside work tree: $source_path"
  target_rel="$(path_relative_to_work_tree "$target_path")" || fail "Path is outside work tree: $target_path"

  if is_tracked "$source_rel"; then
    source_tracked=1
  fi

  if [[ -e "$source_path" || -L "$source_path" ]]; then
    if [[ -e "$target_path" || -L "$target_path" ]]; then
      fail "Both source and target exist; resolve manually: $source_path and $target_path"
    fi

    mv "$source_path" "$target_path"
    if (( source_tracked == 1 )); then
      remove_from_index "$source_rel"
      dotfiles_git add -- "$target_rel"
      log "Renamed tracked $source_rel -> $target_rel"
    else
      dotfiles_git add -- "$target_rel"
      log "Moved untracked $source_rel -> $target_rel and added $target_rel"
    fi
    return
  fi

  if [[ -e "$target_path" || -L "$target_path" ]]; then
    if (( source_tracked == 1 )); then
      remove_from_index "$source_rel"
      dotfiles_git add -- "$target_rel"
      log "Completed partial migration for $source_rel -> $target_rel"
      return
    fi

    if is_tracked "$target_rel"; then
      log "Already migrated: $target_rel"
      return
    fi

    fail "Target already exists and source is missing: $target_path"
  fi

  if (( source_tracked == 1 )); then
    fail "Tracked file $source_rel is missing from the work tree"
  fi

  log "Skipping missing $source_rel"
}

main() {
  validate_repo
  remove_stray_readme
  rename_shell_file "$ZSHRC_PATH" "$ZSHRC_MANAGED_PATH"
  rename_shell_file "$BASHRC_PATH" "$BASHRC_MANAGED_PATH"
  dotfiles_git status --short
}

main "$@"
